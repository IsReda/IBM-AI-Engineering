{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Sync Notebook to GitHub",
      "type": "shell",
      "command": "python scripts/sync_notebook.py '${file}'",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "📥 Install Dependencies",
      "type": "shell",
      "command": "pip install jupytext nbconvert",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "📊 Git Status",
      "type": "shell",
      "command": "git status",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "📜 Git Log",
      "type": "shell",
      "command": "git log --oneline -10",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
